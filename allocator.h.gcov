        -:   25:/**
        -:   26: * @brief Custom memory allocator interface.
        -:   27: *
        -:   28: * All LibZenit containers accept a custom allocator via `_with_allocator`
        -:   29: * constructor variants.  Passing #ZENIT_ALLOCATOR_DEFAULT uses the standard
        -:   30: * malloc / realloc / free.
        -:   31: *
        -:   32: * If @p realloc_fn is NULL, the library falls back to allocate-copy-free
        -:   33: * for reallocation operations (slower but compatible with allocators that
        -:   34: * do not support realloc, such as arena allocators).
        -:   35: */
        -:   36:typedef struct {
        -:   37:    /** @brief Allocate @p size bytes.  Must return NULL on failure. */
        -:   38:    void *(*alloc_fn)(size_t size, void *ctx);
        -:   39:    /** @brief Reallocate @p ptr to @p size bytes, or NULL if unsupported. */
        -:   40:    void *(*realloc_fn)(void *ptr, size_t size, void *ctx);
        -:   41:    /** @brief Free a pointer previously returned by alloc_fn or realloc_fn. */
        -:   42:    void (*free_fn)(void *ptr, void *ctx);
        -:   43:    /** @brief Opaque context forwarded to every function call. */
        -:   44:    void *ctx;
        -:   45:} zenit_allocator_t;
        -:   46:
        -:   47:/** @brief Default allocator using libc malloc / realloc / free. */
       40:   48:static inline void *zenit_default_alloc(size_t size, void *ctx) {
        -:   49:    (void)ctx;
       40:   50:    return malloc(size);
        -:   51:}
