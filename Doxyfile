PROJECT_NAME           = "LibZenit"
PROJECT_NUMBER         = 0.1.0
PROJECT_BRIEF          = "Portable C building blocks for systems programming"
OUTPUT_DIRECTORY       = docs
INPUT                  = include/libzenit
RECURSIVE              = NO
FILE_PATTERNS          = *.h
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
OPTIMIZE_OUTPUT_FOR_C  = YES
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = "static_inline=static inline"
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
SOURCE_BROWSER         = NO
ALPHABETICAL_INDEX     = YES
CASE_SENSE_NAMES       = YES
TAB_SIZE               = 4
